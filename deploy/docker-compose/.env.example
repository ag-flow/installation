# ag-flow.rag — Configuration production
# Copier en .env et remplir chaque valeur avant de lancer docker compose up -d

# ─────────────────────────────────────────────
# IMAGE
# ─────────────────────────────────────────────
# Tag de l'image à déployer.
# latest  = dernière image buildée sur main (CI GitHub Actions)
# <sha>   = SHA Git court pour épingler une version précise
#           → voir https://github.com/ag-flow/rag/pkgs/container/rag-backend
IMAGE_TAG=latest

# SHA Git affiché dans /version (cosmétique, laisser vide si non utilisé)
GIT_SHA=

# ─────────────────────────────────────────────
# POSTGRESQL
# ─────────────────────────────────────────────
# Identifiants du compte Postgres créé au premier démarrage.
# DATABASE_URL et RAG_POSTGRES_ADMIN_URL sont construits automatiquement
# dans docker-compose.yml — ne pas les définir ici.
POSTGRES_USER=rag
POSTGRES_PASSWORD=          # openssl rand -hex 24
POSTGRES_DB=rag_config

# ─────────────────────────────────────────────
# SÉCURITÉ
# ─────────────────────────────────────────────
# Clé Bearer pour /api/admin/* — traiter comme un mot de passe root
# openssl rand -hex 32
RAG_MASTER_KEY=

# Secret de signature des cookies session OIDC
# openssl rand -hex 32
RAG_SESSION_SECRET=

# Passphrase pgcrypto pour chiffrer les clés API dans Harpocrate
# Obligatoire dès qu'un coffre est créé via l'IHM
# openssl rand -hex 32
HARPOCRATE_DEK=

# Secret HMAC pour signer les payloads webhook sortants (optionnel)
# openssl rand -hex 32
RAG_WEBHOOK_SECRET=

# ─────────────────────────────────────────────
# URL PUBLIQUE
# ─────────────────────────────────────────────
# URL externe vue par les navigateurs et les callbacks OIDC
# Sans slash final — ex : https://rag.yoops.org
RAG_PUBLIC_URL=https://rag.example.com

# ─────────────────────────────────────────────
# COMPTE ADMIN LOCAL (bootstrap)
# ─────────────────────────────────────────────
# Compte de secours pour la première connexion avant configuration OIDC.
# Désactiver après avoir configuré Keycloak : vider PASSWORD_HASH + restart.
RAG_BOOTSTRAP_ADMIN_USERNAME=admin
RAG_BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# Hash bcrypt du mot de passe — générer avec :
#   python3 -c "import bcrypt; print(bcrypt.hashpw(b'MON_MDP', bcrypt.gensalt(12)).decode())"
RAG_BOOTSTRAP_ADMIN_PASSWORD_HASH=

# Durée de vie de la session locale en secondes (8h par défaut)
RAG_BOOTSTRAP_SESSION_TTL_SECONDS=28800

# ─────────────────────────────────────────────
# RÉSEAU
# ─────────────────────────────────────────────
# Port hôte exposé par Caddy (Cloudflare Tunnel pointe sur ce port)
HTTP_PORT=80

# Domaine de base. doc est servi sur doc.{BASE_DOMAIN} ; rag sur l'hôte par défaut.
BASE_DOMAIN=agflow.local

# IP de l'hôte (auto-détectée et réécrite par deploy.sh) — accès direct par IP.
HOST_IP=

# ─────────────────────────────────────────────
# WORKER & LOGS
# ─────────────────────────────────────────────
SYNC_WORKER_POLL_INTERVAL_SECONDS=30
SYNC_DEFAULT_INTERVAL_SECONDS=300
LOG_LEVEL=INFO

# ══════════════════════════════════════════════════════════════════════════════
# DOC (docflow) — produit mutualisé sur le même Postgres
# ══════════════════════════════════════════════════════════════════════════════
# Tag image doc
DOC_IMAGE_TAG=latest

# Mot de passe du rôle Postgres "docflow" (créé par initdb/10-docflow.sh).
# DATABASE_URL de doc est construit dans docker-compose.yml — ne pas le définir ici.
# openssl rand -hex 24
DOC_DB_PASSWORD=

# Clé de signature JWT doc — openssl rand -hex 32
JWT_SECRET=

# Clé de chiffrement Fernet doc — NE JAMAIS changer après le 1er usage.
# python3 -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=

# Compte admin bootstrap doc (break-glass)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# Niveau de log doc
DOC_LOG_LEVEL=INFO

# ══════════════════════════════════════════════════════════════════════════════
# PORTAL (workspace-portal / devpod-ui) — produit mutualisé sur le même Postgres
# ══════════════════════════════════════════════════════════════════════════════
# Tag image portal (CI publie sur la branche main)
PORTAL_IMAGE_TAG=main

# Mot de passe du rôle Postgres "portal" (créé par initdb/20-portal.sh).
# Le DATABASE_URL du portal est écrit dans /data/.env par deploy.sh — pas ici.
# openssl rand -hex 24
PORTAL_DB_PASSWORD=

# ══════════════════════════════════════════════════════════════════════════════
# HOMEPAGE — landing page (liste des ressources), servie sur home.{BASE_DOMAIN}
# ══════════════════════════════════════════════════════════════════════════════
HOMEPAGE_IMAGE_TAG=latest

# Port hôte publié pour l'accès direct à Homepage (hors Caddy) : http://<ip>:<port>
HOMEPAGE_PORT=3000
