# ag-flow — Reverse proxy mutualisé (portal + rag + doc + homepage)
# TLS géré par Cloudflare Tunnel en amont — Caddy tourne en HTTP simple (http://).
#
# Accès PROD (par nom d'hôte, port 80) :
#   {BASE_DOMAIN}       -> portal     ws-*.{BASE_DOMAIN} -> routes dynamiques (srv0)
#   home.{BASE_DOMAIN}  -> homepage
#   doc.{BASE_DOMAIN}   -> doc
#   rag.{BASE_DOMAIN}   -> rag (split backend/frontend)
#
# Accès DIRECT par IP (debug/test, sans nom d'hôte) :
#   :{PORTAL_PORT}=8081 -> portal   :{DOC_PORT}=8082 -> doc   :{RAG_PORT}=8083 -> rag
#   (homepage est publié séparément sur son propre port conteneur :3000)

{
    # API admin Caddy (réseau interne) — le portal y injecte les routes ws-* (srv0).
    admin 0.0.0.0:2019
}

# ── Snippets réutilisés (nom d'hôte ET accès direct par port) ───────────────
(rag_routes) {
    handle /api/* {
        reverse_proxy backend:8000
    }
    handle /auth/* {
        reverse_proxy backend:8000
    }
    handle /me {
        reverse_proxy backend:8000
    }
    handle /ws/* {
        reverse_proxy backend:8000 {
            transport http {
                keepalive 86400s
            }
        }
    }
    handle /workspaces/* {
        reverse_proxy backend:8000 {
            transport http {
                read_timeout 120s
                write_timeout 120s
            }
        }
    }
    handle /mcp {
        reverse_proxy backend:8000
    }
    handle /api/webhooks/* {
        reverse_proxy backend:8000
    }
    handle /health {
        reverse_proxy backend:8000
    }
    handle /version {
        reverse_proxy backend:8000
    }
    handle /openapi.json {
        reverse_proxy backend:8000
    }
    handle /docs* {
        reverse_proxy backend:8000
    }
    handle /redoc* {
        reverse_proxy backend:8000
    }
    handle /ui* {
        reverse_proxy frontend:80
    }
}

(portal_proxy) {
    reverse_proxy portal:8080 {
        flush_interval -1
        transport http {
            read_timeout 0
            write_timeout 0
        }
    }
}

# ════════════════════════════════════════════════════════════════════════════
# Accès par nom d'hôte (port 80) — srv0 défini en premier (routes ws-* du portal)
# ════════════════════════════════════════════════════════════════════════════
http://{$BASE_DOMAIN} {
    import portal_proxy
}

http://home.{$BASE_DOMAIN} {
    reverse_proxy homepage:3000
}

http://doc.{$BASE_DOMAIN} {
    reverse_proxy doc:8080
}

http://rag.{$BASE_DOMAIN} {
    import rag_routes
    handle {
        respond "ag-flow.rag — interface : /ui  •  API : /api/*  •  doc : /docs" 200
    }
}

# ════════════════════════════════════════════════════════════════════════════
# Accès direct par IP:port (debug/test) — pas de nom d'hôte requis
# ════════════════════════════════════════════════════════════════════════════
:{$PORTAL_PORT:8081} {
    import portal_proxy
}

:{$DOC_PORT:8082} {
    reverse_proxy doc:8080
}

:{$RAG_PORT:8083} {
    import rag_routes
    handle {
        reverse_proxy frontend:80
    }
}
